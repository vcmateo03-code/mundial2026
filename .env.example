# ─────────────────────────────────────────
# MUNDIAL 2026 — Environment Variables
# Set these in the Vercel dashboard under Project → Settings → Environment Variables
# NEVER commit real values to git
# ─────────────────────────────────────────

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# football-data.org — free tier at https://www.football-data.org/
FOOTBALL_API_KEY=your-football-data-api-key

# Competition ID for FIFA World Cup 2026 (usually 2000 on football-data.org)
FOOTBALL_COMPETITION_ID=2000

# Vercel Cron Secret — set any random string here, add the same value in Vercel dashboard
# Vercel sends this as "Authorization: Bearer <CRON_SECRET>" on cron requests
CRON_SECRET=your-random-secret-string
