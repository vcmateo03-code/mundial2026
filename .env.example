# ─────────────────────────────────────────
# MUNDIAL 2026 — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# football-data.org — free tier at https://www.football-data.org/
# Free tier: 10 req/min, full competition data
FOOTBALL_API_KEY=your-football-data-api-key

# Competition ID for FIFA World Cup 2026 on football-data.org
# WC = FIFA World Cup (check API docs for 2026 specific ID, usually 2000)
FOOTBALL_COMPETITION_ID=2000

# Optional: RapidAPI key if using api-football as fallback
# RAPIDAPI_KEY=your-rapidapi-key
